          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField expression="(([price] - [cost] - [freight_value]) / [price]) * 100" field="Profit Margin (%)" size="8" type="Double" enabled="true" />
                <FormulaField expression="(([Right_price] - [price]) / [Right_price]) * 100" field="Discount Rate (%)" size="8" type="Double" enabled="true" />
                <FormulaField expression="DateTimeYear([Purchase_Date_Out])" field="Order Year" size="2" type="Int16" enabled="true" />
              </FormulaFields>
            </Configuration>
            <Annotation DisplayMode="0">
              <Name />
              <DefaultAnnotationText>Profit Margin (%) = (([price] - [cost] - [freight_value]) / [price]) * 100
Disco...</DefaultAnnotationText>
              <Left value="False" />
